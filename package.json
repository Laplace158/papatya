{
  "name": "papatya",
  "version": "1.0.10",
  "description": "A lightweight Papatya background clip recorder.",
  "main": "src/main.js",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "shortcuts": "powershell -ExecutionPolicy Bypass -File scripts/create-shortcuts.ps1",
    "repair-clips": "node scripts/repair-clips.js",
    "sync-publish": "node scripts/sync-publish-config.js",
    "check": "node --check scripts/start-electron.js && node --check scripts/repair-clips.js && node --check src/main.js && node --check src/preload.js && node --check src/renderer.js",
    "pack": "electron-builder --win nsis",
    "dist": "node scripts/sync-publish-config.js && electron-builder --win nsis --publish never",
    "dist:github": "node scripts/sync-publish-config.js && electron-builder --win nsis --publish always"
  },
  "keywords": [
    "electron",
    "clip",
    "recorder"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "ffmpeg-static": "^5.3.0",
    "webm-duration-fix": "^1.0.4"
  },
  "build": {
    "appId": "com.papatya.cliprecorder",
    "productName": "Papatya",
    "asar": true,
    "asarUnpack": [
      "assets/audio-loopback/**"
    ],
    "files": [
      "src/**/*",
      "scripts/**/*",
      "assets/**/*",
      "Papatya.vbs",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Papatya-Setup-${version}.${ext}",
      "icon": "assets/papatya.ico",
      "requestedExecutionLevel": "highestAvailable"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Papatya"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Laplace158",
        "repo": "papatya",
        "releaseType": "release"
      }
    ]
  }
}
